# Copy this file to terraform.tfvars and fill in the values.
# Never commit terraform.tfvars — it contains sensitive credentials.

aws_region = "us-east-1"

environment = "mvp"

project = "backstage"

# GitHub repository in org/repo format — used to scope the OIDC trust policy
github_repository = "Pabloin/DevOpsDays-BA"

vpc_cidr = "10.0.0.0/16"

availability_zones = ["us-east-1a", "us-east-1b"]

# Custom domain for the portal — a Route 53 hosted zone and ACM certificate will be created.
# After apply, add the portal_nameservers output as an NS record in the registrar account.
domain_name = "portal.glaciar.org"

# Docker image tag to deploy. Typically set by CI/CD (e.g. the Git SHA).
image_tag = "latest"

# GitHub OAuth app credentials — create at https://github.com/settings/developers
github_oauth_client_id     = "<your-github-oauth-client-id>"
github_oauth_client_secret = "<your-github-oauth-client-secret>"

# Number of ECR images to keep; older images are pruned by lifecycle policy
image_retention_count = 10
